# ── Claude API ──────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email (Gmail) ────────────────────────────────────────────────────────────
# The Gmail address that SENDS the digest
EMAIL_SENDER=you@gmail.com

# Gmail App Password (NOT your regular password).
# How to create one: https://myaccount.google.com/apppasswords
# Enable 2FA first, then generate a 16-character App Password.
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that RECEIVES the digest (can be same as sender)
EMAIL_RECIPIENT=you@gmail.com
